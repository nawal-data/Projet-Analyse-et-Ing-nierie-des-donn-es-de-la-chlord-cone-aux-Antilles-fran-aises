834049, 0.121], [1622049.68864105, 715787.505552178, 0.2], [1622075.11579703, 715884.457506122, 0.2], [1622059.63164391, 715849.740567703, 0.2], [1622058.11260662, 715838.668118511, 0.2], [1617107.95644012, 716882.609295348, 2.73], [1617181.9261641, 717274.402688457, 2.73], [1617366.09493848, 717060.493353318, 2.73], [1617094.31061811, 716894.189504384, 2.73], [1617197.07882677, 717190.414803124, 2.73], [1621455.03810066, 715858.20561696, 0.324], [1621392.19014367, 715914.340144053, 0.171], [1619718.22486643, 727067.796827708, 0.0026], [1619719.55448963, 727077.182460722, 0.0026], [1642845.57339451, 706291.110207331, 0.057], [1642672.95725731, 706524.739207261, 0.057], [1642797.29290898, 706238.798301847, 0.057], [1642786.08358284, 706236.959983153, 0.057], [1642834.31152053, 706235.614210033, 0.057], [1622447.02588571, 715796.114605396, 0.276], [1622449.70776141, 715802.786111461, 0.276], [1622448.15793552, 715805.397860855, 0.276], [1622462.47558005, 715813.200408344, 0.276], [1642014.80236292, 705754.659657813, 0.0301], [1642025.22275635, 705736.250140949, 0.0301], [1609312.31740838, 719733.039384772, 0.085], [1609318.54223572, 719721.473842118, 0.085], [1609321.42635892, 719730.338134864, 0.085]],\n",
