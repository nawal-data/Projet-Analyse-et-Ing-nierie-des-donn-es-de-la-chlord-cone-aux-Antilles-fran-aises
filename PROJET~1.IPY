      }
    },
    {
      "cell_type": "code",
      "source": [
        "topo_cols = [\n",
        "    \"mnt_tpi_mean\",\"mnt_tri_mean\",\"mnt_rugosite_mean\",\n",
        "    \"mnt_ombrage_mean\",\"mnt_exposition_mean\",\"mnt_pente_mean\"\n",
        "]\n",
        "\n",
        "for col in topo_cols:\n",
        "    df[col] = df[col].astype(str).str.replace(\",\", \".\", regex=False)\n",
        "    df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n",
        "\n",
        "df[topo_cols].describe()\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 300
        },
        "id": "gyo2PpPfWs1x",
        "outputId": "abcabcf1-5c46-468b-c9a0-36e50e79f5a5"
